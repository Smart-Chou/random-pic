# R2 Configuration
R2_ACCOUNT_ID=your_account_id
R2_BUCKET=your_bucket_name
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key

# R2 Custom Domain
IMAGE_BASE_URL=your-domain.com
IMAGE_HOSTNAME=your-image-api.your-domain.com

# Referer Whitelist
REFERER_WHITELIST=example.com,localhost

# Security - Token Authentication
# TOKEN_SECRET=your-secret-key-change-me
# TOKEN_EXPIRY_DEFAULT=3600
# FORCE_WATERMARK=false

# Local Upload Configuration
# UPLOAD_DIR=./public/uploads
# UPLOAD_MAX_SIZE=10485760
# IMAGES_JSON_PATH=./data/images.json